{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:web",
  "framework": "vite",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "installCommand": "npm ci",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/PayDance",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/PayDance/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/PayDance/en",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/PayDance/en/",
      "destination": "/en/",
      "permanent": true
    }
  ]
}
